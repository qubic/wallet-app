default_platform(:ios)

platform :ios do

  desc "🔧 Build and upload to TestFlight (interactive, local use)"
  lane :testflight_release do
    xcversion(version: ENV["XCODE_VERSION"])

    app_store_connect_api_key(
      key_id: ENV["APP_STORE_KEY_ID"],
      issuer_id: ENV["APP_STORE_ISSUER_ID"],
      key_filepath: "AuthKey.p8"
    )

    sh "flutter clean"
    sh "flutter pub get"
    sh "flutter build ios --no-codesign"
    sh "pod install"

    build_app(
      scheme: "Runner",
      export_method: "app-store",
      skip_package_ipa: false,
      silent: false,
      clean: true,
      xcargs: "-allowProvisioningUpdates",
      export_options: {
        signingStyle: "automatic",
        method: "app-store",
        provisioningProfiles: {
          "org.qubic.wallet" => "Wallet distribution profile"
        },
        manageAppVersionAndBuildNumber: true
      }
    )

    upload_to_testflight
  end

  desc "🤖 CI: Build and upload silently to TestFlight"
  lane :ci_testflight_release do
    xcversion(version: ENV["XCODE_VERSION"])

    app_store_connect_api_key(
      key_id: ENV["APP_STORE_KEY_ID"],
      issuer_id: ENV["APP_STORE_ISSUER_ID"],
      key_filepath: "AuthKey.p8"
    )

    build_app(
      scheme: "Runner",
      export_method: "app-store",
      configuration: "Release",   # <- FORCE Release build
      skip_package_ipa: false,
      silent: false,
      clean: true,
      xcargs: "-allowProvisioningUpdates",
      export_options: {
        signingStyle: "automatic",
        method: "app-store",
        provisioningProfiles: {
          "org.qubic.wallet" => "Wallet distribution profile"
        },
        manageAppVersionAndBuildNumber: true
      }
    )

    upload_to_testflight(
      skip_waiting_for_build_processing: true,
      distribute_external: false
    )
  end

end